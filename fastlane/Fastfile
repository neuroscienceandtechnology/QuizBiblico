require 'spaceship'

default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY"]
    )

    # Revoke orphaned distribution certs if at the 2-cert limit
    begin
      dist_certs = Spaceship::ConnectAPI::Certificate.all.select { |c|
        ["DISTRIBUTION", "IOS_DISTRIBUTION"].include?(c.certificate_type.to_s)
      }
      UI.message("Distribution certs in portal: #{dist_certs.count}")
      if dist_certs.count >= 2
        UI.message("At cert limit — revoking orphaned certs")
        dist_certs.each do |cert|
          Spaceship::ConnectAPI.delete_certificate(certificate_id: cert.id)
          UI.success("Revoked #{cert.id} (#{cert.name})")
        end
      end
    rescue => e
      UI.message("Cert cleanup skipped: #{e.message}")
    end

    keychain_name = "match_ci.keychain"
    keychain_password = "MatchCI_Keychain_Pass"
    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: false,
      unlock: true,
      timeout: 0,
      add_to_search_list: true
    )

    match(
      type: "appstore",
      app_identifier: ["com.matheusresende.quizbiblico"],
      git_url: ENV["MATCH_GIT_URL"],
      git_branch: "certs-storage",
      api_key: api_key,
      readonly: false,
      force: false,
      keychain_name: keychain_name,
      keychain_password: keychain_password
    )

    build_number = ENV["GITHUB_RUN_NUMBER"] || "1"
    increment_build_number(build_number: build_number)

    build_app(
      scheme: "QuizBiblico",
      xcargs: {
        "CODE_SIGN_STYLE" => "Manual",
        "CODE_SIGN_IDENTITY" => "Apple Distribution"
      },
      export_method: "app-store",
      export_options: {
        method: "app-store",
        teamID: "2JFJYD6Z9L",
        signingStyle: "manual",
        provisioningProfiles: lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING]
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
